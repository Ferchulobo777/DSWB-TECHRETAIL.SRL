extends layout

block content
  header(style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; background: none; border: none; box-shadow: none; padding: 0;")
    h1 Productos
    a.btn.btn-primary(href="/vistas/productos/nuevo") + Nuevo Producto

  .card
    table
      thead
        tr
          th Código
          th Nombre
          th Precio
          th Stock
          th Descripción
      tbody
        each producto in productos
          tr
            td(style="font-family: monospace; font-weight: 600;")= producto.codigo
            td(style="font-weight: 600;")= producto.nombre
            td= `$${producto.precio.toLocaleString()}`
            td
              span(style=producto.stock < 5 ? "color: #ef4444; font-weight: 700;" : "")= producto.stock
            td(style="color: var(--text-muted); font-size: 0.875rem;")= producto.descripcion
        else
          tr
            td(colspan="5" style="text-align: center; padding: 2rem;") No hay productos registrados.
